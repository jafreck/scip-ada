with "aunit";

project Scip_Ada_Tests is

   for Source_Dirs use ("src/", "../src/", "../config/", "../src/lal_stubs/");
   for Object_Dir use "../obj/tests";
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "../bin";
   for Main use ("test_runner.adb");

   package Builder is
      for Executable ("test_runner.adb") use "test_runner";
   end Builder;

   package Compiler is
      for Default_Switches ("Ada") use
        ("-Og", "-g", "-gnatwa", "-gnatW8");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es");
   end Binder;

   package Linker is
      for Default_Switches ("Ada") use ();
   end Linker;

end Scip_Ada_Tests;
