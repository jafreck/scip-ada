project Gen_SCIP_Test is
   for Source_Dirs use ("src/", "config/", "src/lal_stubs/");
   for Object_Dir use "obj/e2e";
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("gen_scip.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-Og");
   end Compiler;
end Gen_SCIP_Test;
